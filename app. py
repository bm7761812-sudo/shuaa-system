# 6. اختيار الشاشة الحالية
current_tab = st.radio(
    "اختر الشاشة التي تريد العمل عليها حالياً:",
    ["🏠 الصفحة الرئيسية", "📦 اصناف مخزنية", "📥 الاستلام المخزني", "👥 تعريف عميل", "📄 فاتورة مبيعات"],
    horizontal=True
)

st.markdown("---")

if current_tab == "🏠 الصفحة الرئيسية":
    st.subheader("🏠 لوحة التحكم والمراقبة السريعة")
    col_d1, col_d2, col_d3 = st.columns(3)
    with col_d1: st.markdown(f"<div class='metric-card'><h4>📦 عدد الأصناف</h4><h2>{len(st.session_state.items_df)}</h2></div>", unsafe_allow_html=True)
    with col_d2: st.markdown(f"<div class='metric-card'><h4>👥 إجمالي العملاء</h4><h2>{len(st.session_state.customers_df)}</h2></div>", unsafe_allow_html=True)
    with col_d3: st.markdown(f"<div class='metric-card'><h4>🧾 الفواتير الصادرة</h4><h2>{len(st.session_state.invoices)}</h2></div>", unsafe_allow_html=True)

elif current_tab == "📦 اصناف مخزنية":
    st.markdown("<div class='header-box'>📦 دليل الأصناف والتحكم بالمخزون</div>", unsafe_allow_html=True)
    st.dataframe(st.session_state.items_df, use_container_width=True)

elif current_tab == "📥 الاستلام المخزني":
    st.markdown("<div class='header-box'>📥 حركة إدخال واستلام مخزني</div>", unsafe_allow_html=True)
    col_in1, col_in2, col_in3 = st.columns(3)
    selected_item = col_in1.selectbox("اختر الصنف", st.session_state.items_df["اسم الصنف"])
    qty_in = col_in2.number_input("الكمية الواردة", min_value=1, value=10)
    if col_in3.button("📥 تأكيد الاستلام"):
        st.session_state.items_df.loc[st.session_state.items_df["اسم الصنف"] == selected_item, "المخزون الحالي"] += qty_in
        st.success("تم التوريد بنجاح!")

elif current_tab == "👥 تعريف عميل":
    st.markdown("<div class='header-box'>👥 فتح ملف وتكويد عميل جديد</div>", unsafe_allow_html=True)
    with st.form("cust_form"):
        cust_name = st.text_input("اسم العميل الكامل")
        if st.form_submit_button("💾 حفظ العميل"):
            new_cust = {"رقم العميل": len(st.session_state.customers_df)+1, "اسم العميل": cust_name, "الهاتف": "", "العنوان": "", "الرصيد": 0.0}
            st.session_state.customers_df = pd.concat([st.session_state.customers_df, pd.DataFrame([new_cust])], ignore_index=True)
            st.success("تم الحفظ!")
            st.rerun()
    st.dataframe(st.session_state.customers_df, use_container_width=True)

elif current_tab == "📄 فاتورة مبيعات":
    st.markdown("<div style='background-color: #00ffff; padding: 8px; border-radius: 4px; text-align: center; color: black; font-weight: bold; border: 2px solid #1e3a8a;'>📄 شاشة إصدار فاتورة مبيعات إلكترونية</div>", unsafe_allow_html=True)
    
    col_f1, col_f2 = st.columns(2)
    with col_f1:
        st.text_input("رقم الفاتورة", value=f"INV-{len(st.session_state.invoices)+1:04d}", disabled=True)
        active_customer = st.selectbox("اسم العميل", st.session_state.customers_df["اسم العميل"])
    with col_f2:
        currency = st.selectbox("العملة", ["ريال يمني", "ريال سعودي", "دولار أمريكي"])
    
    st.markdown("---")
    col_h1, col_h2, col_h3 = st.columns([3, 1, 2])
    selected_i1 = col_h1.selectbox("الصنف", st.session_state.items_df["اسم الصنف"])
    price_i1 = st.session_state.items_df.loc[st.session_state.items_df["اسم الصنف"] == selected_i1, "سعر البيع"].values[0]
    qty_i1 = col_h2.number_input("الكمية", min_value=1, value=1)
    tot_i1 = qty_i1 * price_i1
    col_h3.text_input("الإجمالي", value=f"{tot_i1:,.2f} {currency}", disabled=True)
    
    if st.button("💾 حفظ وترحيل الفاتورة"):
        st.session_state.invoices.append({"عميل": active_customer, "صافي": tot_i1})
        st.success("تم ترحيل الفاتورة بنجاح وحفظها في الدفاتر الحسابية!")
