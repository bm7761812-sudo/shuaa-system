# 5. شريط محاكاة النظام الثابت بالرمادي الفاتح
col_m1, col_m2, col_m3, col_m4, col_m5, col_m6 = st.columns(6)
col_m1.markdown("<div class='erp-main-btn'>⚙️ النظام</div>", unsafe_allow_html=True)
col_m2.markdown("<div class='erp-main-btn'>📊 الأستاذ العام</div>", unsafe_allow_html=True)
col_m3.markdown("<div class='erp-main-btn'>📦 المخازن</div>", unsafe_allow_html=True)
col_m4.markdown("<div class='erp-main-btn'>📈 المبيعات</div>", unsafe_allow_html=True)
col_m5.markdown("<div class='erp-main-btn'>🏪 نقاط البيع</div>", unsafe_allow_html=True)
